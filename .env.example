# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider (pick one)
GEMINI_API_KEY=               # Gemini (recommended, free tier available)
# OPENAI_API_KEY=             # OpenAI (GPT-4o-mini default)
# ANTHROPIC_API_KEY=          # Anthropic Claude (claude-haiku default)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama, vLLM)
# LLM_MODEL=                  # Override model name for any provider

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
